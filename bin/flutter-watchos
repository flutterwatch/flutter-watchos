# found in the LICENSE file.

set -e

# Needed because if it is set, cd may print the path it changed to.
unset CDPATH

# On Mac OS, readlink -f doesn't work, so follow_links traverses the path one
# link at a time, and then cds into the link destination and find out where it
# ends up.
function follow_links() (
  cd -P "$(dirname -- "$1")"
  file="$PWD/$(basename -- "$1")"
  while [[ -h "$file" ]]; do
    cd -P "$(dirname -- "$file")"
    file="$(readlink -- "$file")"
    cd -P "$(dirname -- "$file")"
    file="$PWD/$(basename -- "$file")"
  done
  echo "$file"
)

PROG_NAME="$(follow_links "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "${PROG_NAME%/*}" ; pwd -P)"
OS="$(uname -s)"

# Only macOS is supported for watchOS development.
if [[ "$OS" != "Darwin" ]]; then
  echo "flutter-watchos only supports macOS."
  exit 1
fi

source "$BIN_DIR/internal/shared.sh"

# Clone or update the flutter repo.
update_flutter

# Set up proxy_root with correct symlinks.
setup_proxy_root

# Upgrade flutter-watchos if needed.
update_flutter_watchos

# Run the snapshot.
exec_snapshot "$@"
